{
  "name": "@blockrun/franklin",
  "version": "3.0.2",
  "description": "Franklin — The AI agent with a wallet. Marketing at franklin.run, trading at franklin.bet. Pay per action in USDC.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin-sdk": {
      "types": "./dist/plugin-sdk/index.d.ts",
      "default": "./dist/plugin-sdk/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "franklin": "./dist/index.js",
    "runcode": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-plugin-assets.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npm run build && node --test --test-reporter=spec test/local.mjs",
    "test:e2e": "npm run build && node --test --test-reporter=spec test/e2e.mjs",
    "test:all": "npm run test && npm run test:e2e",
    "test:watch": "node --test --watch test/local.mjs",
    "test:e2e:watch": "node --test --watch test/e2e.mjs"
  },
  "keywords": [
    "franklin",
    "autonomous-economic-agent",
    "ai-agent",
    "wallet-native",
    "agent-with-wallet",
    "x402",
    "usdc",
    "pay-per-action",
    "multi-model",
    "ai-marketing",
    "ai-trading",
    "crypto-native",
    "blockrun",
    "runcode"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlockRunAI/franklin"
  },
  "homepage": "https://franklin.run",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@blockrun/llm": "^1.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/react": "^19.2.14",
    "bs58": "^6.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
